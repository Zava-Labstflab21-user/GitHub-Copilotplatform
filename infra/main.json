              "type": "string"
            }
          },
          "resources": [
            {
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "scope": "[format('Microsoft.ContainerRegistry/registries/{0}', last(split(parameters('scopeResourceId'), '/')))]",
              "name": "[guid(parameters('scopeResourceId'), parameters('principalId'), parameters('roleDefinitionId'))]",
              "properties": {
